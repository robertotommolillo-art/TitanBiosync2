<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cerca esercizio" />

    <Button
        android:id="@+id/searchOnlineButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerca online"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

    <!-- Superset pending banner: shown only when choosing the 2nd exercise for a superset -->
    <LinearLayout
        android:id="@+id/supersetBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFF3E0"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/supersetBannerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleziona il 2° esercizio per la superserie"
            android:textStyle="bold"
            android:textColor="#E65100" />

        <Button
            android:id="@+id/cancelSupersetButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Annulla superserie"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="12dp" />

</LinearLayout>